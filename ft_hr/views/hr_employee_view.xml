<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_employee_form_inherit_employee_code" model="ir.ui.view">
        <field name="name">hr.employee.form.employee.code</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//h1/field[@name='name']" position="after">
                <span class="ms-2 d-inline-flex align-items-center">
                    <field name="employee_code" placeholder="Employee Code"/>
                </span>
            </xpath>
        </field>
    </record>
</odoo>

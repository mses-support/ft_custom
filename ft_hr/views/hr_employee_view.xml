<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_employee_form_inherit_employee_code" model="ir.ui.view">
        <field name="name">hr.employee.form.employee.code</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='citizenship']" position="inside">
                <field name="employee_code" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>

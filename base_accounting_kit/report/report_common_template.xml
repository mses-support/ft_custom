<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="report_common_header_and_style">
        <style type="text/css">
            .bk-report-table {
                width: 100%;
                table-layout: fixed;
            }
            .bk-report-table th,
            .bk-report-table td {
                word-wrap: break-word;
                overflow-wrap: anywhere;
                vertical-align: top;
                font-size: 11px;
                line-height: 1.35;
                padding: 5px 8px !important;
            }
            .bk-report-table thead th {
                font-weight: 700;
                padding-top: 6px !important;
                padding-bottom: 6px !important;
            }
            .bk-report-table .text-end,
            .bk-report-table .text-right {
                white-space: nowrap;
            }
            .bk-report-company-logo {
                max-height: 64px;
                max-width: 220px;
                object-fit: contain;
            }
        </style>
    </template>
</odoo>

<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <template id="report_general_ledger">
        <t t-call="web.html_container">
            <t t-set="data_report_margin_top" t-value="8"/>
            <t t-set="data_report_header_spacing" t-value="0"/>
            <t t-set="data_report_dpi" t-value="96"/>
            <div class="page gl-root">
                <t t-call="base_accounting_kit.report_common_header_and_style"/>
                <style>
                    .gl-root {
                        clear: both;
                        margin-top: 0 !important;
                        padding-top: 0 !important;
                        font-family: "DejaVu Sans", "Noto Sans", Arial, sans-serif;
                        color: #10243e;
                    }
                    .gl-head {
                        background: #f1f4fa;
                        border: 1px solid #d7deec;
                        border-radius: 4px;
                        padding: 12px 14px;
                        margin-bottom: 10px;
                    }
                    .gl-head-inner {
                        display: table;
                        width: 100%;
                    }
                    .gl-head-logo-wrap {
                        display: table-cell;
                        width: 120px;
                        vertical-align: middle;
                    }
                    .gl-head-logo {
                        max-height: 54px;
                        max-width: 110px;
                        object-fit: contain;
                    }
                    .gl-head-title-wrap {
                        display: table-cell;
                        text-align: center;
                        vertical-align: middle;
                    }
                    .gl-title {
                        color: #1f3b63;
                        font-size: 22px;
                        font-weight: 700;
                        margin: 0;
                        line-height: 1.2;
                    }
                    .gl-meta {
                        width: 100%;
                        border-collapse: separate;
                        border-spacing: 0;
                        margin-bottom: 10px;
                    }
                    .gl-meta td {
                        padding: 4px 8px;
                        vertical-align: top;
                        font-size: 12px;
                        line-height: 1.25;
                    }
                    .gl-meta .label {
                        color: #475569;
                        width: 16%;
                        font-weight: 600;
                    }
                    .gl-table {
                        width: 100%;
                        border-collapse: collapse;
                        table-layout: fixed;
                    }
                    .gl-table th,
                    .gl-table td {
                        border: 1px solid #d7deec;
                        padding: 7px 9px;
                        font-size: 11px;
                        line-height: 1.2;
                        overflow-wrap: anywhere;
                    }
                    .gl-table th {
                        background: #eef2fb;
                        color: #1f3b63;
                        font-weight: 700;
                    }
                    .gl-table .amt-col {
                        text-align: right;
                        white-space: nowrap;
                        font-family: "DejaVu Sans", "Noto Sans", Arial, sans-serif;
                        font-weight: 600;
                    }
                    .gl-account-row td {
                        background: #f8fafd;
                        font-weight: 700;
                    }
                </style>
                <div class="gl-head">
                    <div class="gl-head-inner">
                        <div class="gl-head-logo-wrap">
                            <img t-if="env.company.logo" class="gl-head-logo" t-att-src="image_data_uri(env.company.logo)" alt="Logo"/>
                        </div>
                        <div class="gl-head-title-wrap">
                            <h2 class="gl-title">General Ledger</h2>
                        </div>
                    </div>
                </div>
                <table class="gl-meta">
                    <tr>
                        <td class="label">Date From</td>
                        <td t-esc="data['date_from'] or ''"/>
                        <td class="label">Date To</td>
                        <td t-esc="data['date_to'] or ''"/>
                    </tr>
                    <tr>
                        <td class="label">Journals</td>
                        <td t-esc="', '.join([lt or '' for lt in print_journal])"/>
                        <td class="label">Target Moves</td>
                        <td>
                            <span t-if="data['target_move'] == 'all'">All Entries</span>
                            <span t-if="data['target_move'] == 'posted'">All Posted Entries</span>
                        </td>
                    </tr>
                    <tr>
                        <td class="label">Display Account</td>
                        <td>
                            <span t-if="data['display_account'] == 'all'">All accounts</span>
                            <span t-if="data['display_account'] == 'movement'">With movements</span>
                            <span t-if="data['display_account'] == 'not_zero'">With balance not equal to zero</span>
                        </td>
                        <td class="label">Sorted By</td>
                        <td>
                            <span t-if="data['sortby'] == 'sort_date'">Date</span>
                            <span t-if="data['sortby'] == 'sort_journal_partner'">Journal and Partner</span>
                        </td>
                    </tr>
                    <tr>
                        <td class="label">Analytic Plans</td>
                        <td t-esc="', '.join([x or '' for x in analytic_plans]) if analytic_plans else 'All'"/>
                        <td class="label">Analytic Accounts</td>
                        <td t-esc="', '.join([x or '' for x in analytic_accounts]) if analytic_accounts else 'All'"/>
                    </tr>
                </table>

                <table class="gl-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>JRNL</th>
                            <th>Partner</th>
                            <th>Ref</th>
                            <th>Move</th>
                            <th>Entry Label</th>
                            <th class="amt-col">Debit</th>
                            <th class="amt-col">Credit</th>
                            <th class="amt-col">Balance</th>
                            <th groups="base.group_multi_currency">Currency</th>
                        </tr>
                    </thead>
                    <tbody>
                        <t t-foreach="Accounts" t-as="account">
                            <tr class="gl-account-row">
                                <td colspan="6">
                                    <span t-esc="account['code']"/> - <span t-esc="account['name']"/>
                                </td>
                                <td class="amt-col">
                                    <span t-esc="account['debit']" t-options="{'widget': 'monetary', 'display_currency': env.company.currency_id}"/>
                                </td>
                                <td class="amt-col">
                                    <span t-esc="account['credit']" t-options="{'widget': 'monetary', 'display_currency': env.company.currency_id}"/>
                                </td>
                                <td class="amt-col">
                                    <span t-esc="account['balance']" t-options="{'widget': 'monetary', 'display_currency': env.company.currency_id}"/>
                                </td>
                                <td groups="base.group_multi_currency"/>
                            </tr>
                            <tr t-foreach="account['move_lines']" t-as="line">
                                <td><span t-esc="line['ldate']"/></td>
                                <td><span t-esc="line['lcode']"/></td>
                                <td><span t-esc="line['partner_name']"/></td>
                                <td><span t-if="line['lref']" t-esc="line['lref']"/></td>
                                <td><span t-esc="line['move_name']"/></td>
                                <td><span t-esc="line['lname']"/></td>
                                <td class="amt-col">
                                    <span t-esc="line['debit']" t-options="{'widget': 'monetary', 'display_currency': env.company.currency_id}"/>
                                </td>
                                <td class="amt-col">
                                    <span t-esc="line['credit']" t-options="{'widget': 'monetary', 'display_currency': env.company.currency_id}"/>
                                </td>
                                <td class="amt-col">
                                    <span t-esc="line['balance']" t-options="{'widget': 'monetary', 'display_currency': env.company.currency_id}"/>
                                </td>
                                <td class="amt-col" t-if="line['amount_currency']" groups="base.group_multi_currency">
                                    <span t-esc="line['amount_currency'] if line['amount_currency'] > 0.00 else ''"/>
                                    <span t-esc="line['currency_code'] if line['amount_currency'] > 0.00 else ''"/>
                                </td>
                            </tr>
                        </t>
                    </tbody>
                </table>
            </div>
        </t>
    </template>
</odoo>

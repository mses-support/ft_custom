<odoo>
    <record id="group_po_level2_approver" model="res.groups">
        <field name="name">PO Level 2 Approver</field>
    </record>

    <record id="group_move_reviewer" model="res.groups">
        <field name="name">Invoice/Bill/JE Reviewer</field>
        <field name="privilege_id" ref="account.res_groups_privilege_accounting"/>
        <field name="implied_ids" eval="[(4, ref('account.group_account_user'))]"/>
    </record>

    <record id="group_move_confirmer" model="res.groups">
        <field name="name">Invoice/Bill/JE Confirmer</field>
        <field name="privilege_id" ref="account.res_groups_privilege_accounting"/>
        <field name="implied_ids" eval="[(4, ref('account.group_account_user'))]"/>
    </record>
</odoo>

<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="action_report_customer_invoices_payments" model="ir.actions.report">
        <field name="name">Customer Invoices &amp; Payments</field>
        <field name="model">customer.invoices.payments.report</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">ft_backend.report_customer_invoices_payments</field>
        <field name="report_file">ft_backend.report_customer_invoices_payments</field>
    </record>

    <template id="report_customer_invoices_payments">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page cip-report-root">
                    <t t-call="base_accounting_kit.report_common_header_and_style"/>
                    <style>
                        .cip-report-root {
                            font-size: 11px;
                            color: #000;
                            margin-top: 0;
                            padding-top: 0;
                        }
                        .cip-content {
                            padding-left: 16px !important;
                            padding-right: 16px !important;
                            box-sizing: border-box;
                        }
                        .cip-report-root h2,
                        .cip-report-root p {
                            margin-top: 0;
                        }
                        .cip-table-wrap {
                            overflow-x: auto;
                        }
                        .cip-report-root table {
                            width: 100%;
                            border-collapse: collapse;
                            table-layout: fixed;
                        }
                        .cip-report-root th,
                        .cip-report-root td {
                            border: 1px solid #d5dbe3;
                            padding: 5px 6px;
                            line-height: 1.3;
                            vertical-align: middle;
                        }
                        .cip-report-root th:first-child,
                        .cip-report-root td:first-child {
                            padding-left: 10px !important;
                        }
                        .cip-report-root th:last-child,
                        .cip-report-root td:last-child {
                            padding-right: 10px !important;
                        }
                        .cip-report-root .title {
                            margin: 0 0 4px 0;
                            font-size: 22px;
                            font-weight: 700;
                        }
                        .cip-report-root .subtitle {
                            margin: 0 0 10px 0;
                            font-size: 12px;
                            color: #4f5d73;
                        }
                        .cip-report-root .meta-table {
                            margin-bottom: 10px;
                        }
                        .cip-report-root .meta-table td {
                            border: 1px solid #e3e8ef;
                            background: #f9fbfd;
                        }
                        .cip-report-root .meta-label {
                            width: 120px;
                            font-weight: 700;
                            background: #eef3f9;
                        }
                        .cip-report-root .head-row th {
                            background: #2f5d8a;
                            color: #fff;
                            font-size: 10px;
                            font-weight: 700;
                            white-space: normal;
                            word-break: break-word;
                            line-height: 1.2;
                            text-transform: uppercase;
                            letter-spacing: 0;
                        }
                        .cip-report-root .num {
                            text-align: right;
                            white-space: nowrap;
                            overflow-wrap: anywhere;
                        }
                        .cip-report-root .text-cell {
                            word-break: break-word;
                        }
                        .cip-report-root .col-name { width: 18%; }
                        .cip-report-root .col-type { width: 10%; }
                        .cip-report-root .col-ref { width: 12%; }
                        .cip-report-root .col-date { width: 10%; }
                        .cip-report-root .col-due { width: 10%; }
                        .cip-report-root .col-amt { width: 10%; }
                        .cip-report-root .grand-row td {
                            background: #e7f1ff;
                            font-weight: 700;
                            border-top: 2px solid #2f5d8a;
                        }
                        .cip-report-root .empty-row td {
                            text-align: center;
                            color: #6b7280;
                            padding: 10px;
                        }
                    </style>

                    <div class="cip-content">
                    <h2 class="title" t-esc="report_name"/>
                    <p class="subtitle" t-esc="company_name"/>

                    <table class="meta-table">
                        <tbody>
                            <tr>
                                <td class="meta-label">Period:</td>
                                <td colspan="8"><span t-esc="period_text"/></td>
                            </tr>
                            <tr>
                                <td class="meta-label">Currency:</td>
                                <td colspan="8"><span t-esc="currency_text"/></td>
                            </tr>
                        </tbody>
                    </table>

                    <div class="cip-table-wrap">
                    <table>
                        <tbody>
                            <tr class="head-row">
                                <th class="col-name">Customer Name</th>
                                <th class="col-type">Trans Type</th>
                                <th class="col-ref">Reference</th>
                                <th class="col-date">Date</th>
                                <th class="col-due">Due Date</th>
                                <th class="num col-amt">Invoice</th>
                                <th class="num col-amt">Receipt</th>
                                <th class="num col-amt">Allocated</th>
                                <th class="num col-amt">Balance</th>
                            </tr>

                            <t t-if="not rows">
                                <tr class="empty-row">
                                    <td colspan="9">No customer invoice/payment records in selected period.</td>
                                </tr>
                            </t>

                            <t t-foreach="rows" t-as="row">
                                <tr t-if="row['row_type'] == 'line'">
                                    <td class="text-cell"><span t-esc="row['customer_name']"/></td>
                                    <td class="text-cell"><span t-esc="row['trans_type']"/></td>
                                    <td class="text-cell"><span t-esc="row['reference']"/></td>
                                    <td><span t-esc="row['date']"/></td>
                                    <td><span t-esc="row['due_date']"/></td>
                                    <td class="num"><span t-esc="'%.2f' % row['invoice']"/></td>
                                    <td class="num"><span t-esc="'%.2f' % row['receipt']"/></td>
                                    <td class="num"><span t-esc="'%.2f' % row['allocated']"/></td>
                                    <td class="num"><span t-esc="'%.2f' % row['balance']"/></td>
                                </tr>
                            </t>

                            <tr class="grand-row">
                                <td>Grand Total</td>
                                <td/>
                                <td/>
                                <td/>
                                <td/>
                                <td class="num"><span t-esc="'%.2f' % grand_total['invoice']"/></td>
                                <td class="num"><span t-esc="'%.2f' % grand_total['receipt']"/></td>
                                <td class="num"><span t-esc="'%.2f' % grand_total['allocated']"/></td>
                                <td class="num"><span t-esc="'%.2f' % grand_total['balance']"/></td>
                            </tr>
                        </tbody>
                    </table>
                    </div>
                    </div>
                </div>
            </t>
        </t>
    </template>

</odoo>

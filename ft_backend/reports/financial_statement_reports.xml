<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="action_report_balance_sheet_custom" model="ir.actions.report">
        <field name="name">Balance Sheet (Custom)</field>
        <field name="model">ft.balance.sheet.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">ft_backend.report_balance_sheet_custom</field>
        <field name="report_file">ft_backend.report_balance_sheet_custom</field>
    </record>
    <record id="action_report_balance_sheet_custom_html" model="ir.actions.report">
        <field name="name">Balance Sheet (Custom HTML)</field>
        <field name="model">ft.balance.sheet.wizard</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">ft_backend.report_balance_sheet_custom</field>
        <field name="report_file">ft_backend.report_balance_sheet_custom</field>
    </record>

    <record id="action_report_income_statement_custom" model="ir.actions.report">
        <field name="name">Income Statement (Custom)</field>
        <field name="model">ft.income.statement.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">ft_backend.report_income_statement_custom</field>
        <field name="report_file">ft_backend.report_income_statement_custom</field>
    </record>
    <record id="action_report_income_statement_custom_html" model="ir.actions.report">
        <field name="name">Income Statement (Custom HTML)</field>
        <field name="model">ft.income.statement.wizard</field>
        <field name="report_type">qweb-html</field>
        <field name="report_name">ft_backend.report_income_statement_custom</field>
        <field name="report_file">ft_backend.report_income_statement_custom</field>
    </record>

    <template id="financial_statement_style">
        <style>
            .ft-fs-root { font-size: 12px; color: #000; }
            .ft-fs-title { font-weight: 700; font-size: 22px; margin-bottom: 4px; }
            .ft-fs-subtitle { font-weight: 700; text-decoration: underline; margin-bottom: 8px; }
            .ft-fs-table { width: 100%; border-collapse: collapse; }
            .ft-fs-table td { padding: 3px 8px; }
            .ft-fs-h1 td { background: #3f69b1; color: #000; font-weight: 700; }
            .ft-fs-h2 td { background: #c6d1e6; font-style: italic; font-weight: 700; }
            .ft-fs-total td { border-top: 1px solid #000; border-bottom: 2px solid #000; font-weight: 700; }
            .ft-fs-amt { text-align: right; min-width: 140px; }
            .ft-chip-wrap { margin: 8px 0 10px 0; }
            .ft-chip { display:inline-block; margin:2px 4px 2px 0; padding:4px 8px; border:1px solid #c7ced7; background:#edf1f7; font-size:11px; }
        </style>
    </template>

    <template id="report_balance_sheet_custom">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page ft-fs-root">
                    <t t-call="ft_backend.financial_statement_style"/>
                    <div class="ft-fs-title" t-esc="title"/>
                    <div class="ft-fs-subtitle" t-esc="period_text"/>
                    <div class="ft-chip-wrap">
                        <span class="ft-chip" t-esc="'As of: ' + period_text"/>
                        <span class="ft-chip" t-if="comparison_period_text" t-esc="'Comparison: ' + comparison_period_text"/>
                        <span class="ft-chip" t-esc="'Journals: ' + (filter_summary.get('journals') or 'All Journals')"/>
                        <span class="ft-chip" t-esc="'Analytic Group By: ' + (filter_summary.get('analytics') or 'All')"/>
                        <span class="ft-chip" t-esc="'Options: ' + ('Posted Entries Only' if filter_summary.get('target_move') == 'posted' else 'All Entries')"/>
                    </div>
                    <table class="ft-fs-table">
                        <tbody>
                            <t t-foreach="rows" t-as="row">
                                <tr t-att-class="'ft-fs-total' if row['is_total'] else ('ft-fs-h1' if row['level'] == 0 else ('ft-fs-h2' if row['level'] == 1 else ''))">
                                    <td t-attf-style="padding-left: #{(row['level'] * 20) + 4}px;" t-esc="row['name']"/>
                                    <td class="ft-fs-amt">
                                        <span t-esc="currency"/> <span t-esc="'{:,.2f}'.format(abs(row['amount']))"/>
                                    </td>
                                    <td class="ft-fs-amt">
                                        <span t-if="comparison_period_text"><span t-esc="currency"/> <span t-esc="'{:,.2f}'.format(abs(row['comparison_amount']))"/></span>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>

    <template id="report_income_statement_custom">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page ft-fs-root">
                    <t t-call="ft_backend.financial_statement_style"/>
                    <div t-esc="company.name" style="font-weight:700; margin-bottom:6px;"/>
                    <div class="ft-fs-title" t-esc="title"/>
                    <div class="ft-fs-subtitle" t-esc="period_text"/>
                    <div style="font-weight:700; margin-bottom:8px;" t-esc="'(' + currency + ')'"/>
                    <div class="ft-chip-wrap">
                        <span class="ft-chip" t-esc="'As of: ' + period_text"/>
                        <span class="ft-chip" t-if="comparison_period_text" t-esc="'Comparison: ' + comparison_period_text"/>
                        <span class="ft-chip" t-esc="'Journals: ' + (filter_summary.get('journals') or 'All Journals')"/>
                        <span class="ft-chip" t-esc="'Analytic Group By: ' + (filter_summary.get('analytics') or 'All')"/>
                        <span class="ft-chip" t-esc="'Options: ' + ('Posted Entries Only' if filter_summary.get('target_move') == 'posted' else 'All Entries')"/>
                    </div>
                    <table class="ft-fs-table">
                        <tbody>
                            <t t-foreach="rows" t-as="row">
                                <tr t-att-class="'ft-fs-total' if row['is_total'] else ('ft-fs-h1' if row['level'] == 0 else ('ft-fs-h2' if row['level'] == 1 else ''))">
                                    <td t-attf-style="padding-left: #{(row['level'] * 20) + 4}px;" t-esc="row['name']"/>
                                    <td class="ft-fs-amt">
                                        <span t-esc="currency"/> <span t-esc="'{:,.2f}'.format(abs(row['amount']))"/>
                                    </td>
                                    <td class="ft-fs-amt">
                                        <span t-if="comparison_period_text"><span t-esc="currency"/> <span t-esc="'{:,.2f}'.format(abs(row['comparison_amount']))"/></span>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>
</odoo>

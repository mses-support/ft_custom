<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="action_report_vendor_invoices_payments" model="ir.actions.report">
        <field name="name">Vendor Invoices &amp; Payments</field>
        <field name="model">vendor.invoices.payments.report</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">ft_backend.report_vendor_invoices_payments</field>
        <field name="report_file">ft_backend.report_vendor_invoices_payments</field>
    </record>

    <template id="report_vendor_invoices_payments">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page vip-report-root">
                    <t t-call="base_accounting_kit.report_common_header_and_style"/>
                    <style>
                        .vip-report-root {
                            font-size: 11px;
                            color: #000;
                            margin-top: 0;
                            padding-top: 0;
                        }
                        .vip-content {
                            padding-left: 16px !important;
                            padding-right: 16px !important;
                            box-sizing: border-box;
                        }
                        .vip-report-root h2,
                        .vip-report-root p {
                            margin-top: 0;
                        }
                        .vip-table-wrap {
                            overflow-x: auto;
                        }
                        .vip-report-root table {
                            width: 100%;
                            border-collapse: collapse;
                            table-layout: fixed;
                        }
                        .vip-report-root th,
                        .vip-report-root td {
                            border: 1px solid #d5dbe3;
                            padding: 5px 6px;
                            line-height: 1.3;
                            vertical-align: middle;
                        }
                        .vip-report-root th:first-child,
                        .vip-report-root td:first-child {
                            padding-left: 10px !important;
                        }
                        .vip-report-root th:last-child,
                        .vip-report-root td:last-child {
                            padding-right: 10px !important;
                        }
                        .vip-report-root .title {
                            margin: 0 0 4px 0;
                            font-size: 22px;
                            font-weight: 700;
                        }
                        .vip-report-root .subtitle {
                            margin: 0 0 10px 0;
                            font-size: 12px;
                            color: #4f5d73;
                        }
                        .vip-report-root .meta-table {
                            margin-bottom: 10px;
                        }
                        .vip-report-root .meta-table td {
                            border: 1px solid #e3e8ef;
                            background: #f9fbfd;
                        }
                        .vip-report-root .meta-label {
                            width: 120px;
                            font-weight: 700;
                            background: #eef3f9;
                        }
                        .vip-report-root .head-row th {
                            background: #2f5d8a;
                            color: #fff;
                            font-size: 10px;
                            font-weight: 700;
                            white-space: normal;
                            word-break: break-word;
                            line-height: 1.2;
                            text-transform: uppercase;
                            letter-spacing: 0;
                        }
                        .vip-report-root .num {
                            text-align: right;
                            white-space: nowrap;
                            overflow-wrap: anywhere;
                        }
                        .vip-report-root .text-cell {
                            word-break: break-word;
                        }
                        .vip-report-root .col-name { width: 18%; }
                        .vip-report-root .col-type { width: 10%; }
                        .vip-report-root .col-ref { width: 12%; }
                        .vip-report-root .col-date { width: 10%; }
                        .vip-report-root .col-due { width: 10%; }
                        .vip-report-root .col-amt { width: 10%; }
                        .vip-report-root .grand-row td {
                            background: #e7f1ff;
                            font-weight: 700;
                            border-top: 2px solid #2f5d8a;
                        }
                        .vip-report-root .empty-row td {
                            text-align: center;
                            color: #6b7280;
                            padding: 10px;
                        }
                    </style>

                    <div class="vip-content">
                    <h2 class="title" t-esc="report_name"/>
                    <p class="subtitle" t-esc="company_name"/>

                    <table class="meta-table">
                        <tbody>
                            <tr>
                                <td class="meta-label">Period:</td>
                                <td colspan="8"><span t-esc="period_text"/></td>
                            </tr>
                            <tr>
                                <td class="meta-label">Currency:</td>
                                <td colspan="8"><span t-esc="currency_text"/></td>
                            </tr>
                        </tbody>
                    </table>

                    <div class="vip-table-wrap">
                    <table>
                        <tbody>
                            <tr class="head-row">
                                <th class="col-name">Vendor Name</th>
                                <th class="col-type">Trans Type</th>
                                <th class="col-ref">Reference</th>
                                <th class="col-date">Date</th>
                                <th class="col-due">Due Date</th>
                                <th class="num col-amt">Payments</th>
                                <th class="num col-amt">Invoices</th>
                                <th class="num col-amt">Allocated</th>
                                <th class="num col-amt">Balance</th>
                            </tr>

                            <t t-if="not rows">
                                <tr class="empty-row">
                                    <td colspan="9">No vendor invoice/payment records in selected period.</td>
                                </tr>
                            </t>

                            <t t-foreach="rows" t-as="row">
                                <tr t-if="row['row_type'] == 'line'">
                                    <td class="text-cell"><span t-esc="row['vendor_name']"/></td>
                                    <td class="text-cell"><span t-esc="row['trans_type']"/></td>
                                    <td class="text-cell"><span t-esc="row['reference']"/></td>
                                    <td><span t-esc="row['date']"/></td>
                                    <td><span t-esc="row['due_date']"/></td>
                                    <td class="num">
                                        <span t-esc="'({:,.2f})'.format(abs(row['payments'])) if row['payments'] &lt; 0 else '{:,.2f}'.format(row['payments'])"/>
                                    </td>
                                    <td class="num">
                                        <span t-esc="'({:,.2f})'.format(abs(row['invoices'])) if row['invoices'] &lt; 0 else '{:,.2f}'.format(row['invoices'])"/>
                                    </td>
                                    <td class="num">
                                        <span t-esc="'({:,.2f})'.format(abs(row['allocated'])) if row['allocated'] &lt; 0 else '{:,.2f}'.format(row['allocated'])"/>
                                    </td>
                                    <td class="num">
                                        <span t-esc="'({:,.2f})'.format(abs(row['balance'])) if row['balance'] &lt; 0 else '{:,.2f}'.format(row['balance'])"/>
                                    </td>
                                </tr>
                            </t>

                            <tr class="grand-row">
                                <td>Grand Total</td>
                                <td/>
                                <td/>
                                <td/>
                                <td/>
                                <td class="num">
                                    <span t-esc="'({:,.2f})'.format(abs(grand_total['payments'])) if grand_total['payments'] &lt; 0 else '{:,.2f}'.format(grand_total['payments'])"/>
                                </td>
                                <td class="num">
                                    <span t-esc="'({:,.2f})'.format(abs(grand_total['invoices'])) if grand_total['invoices'] &lt; 0 else '{:,.2f}'.format(grand_total['invoices'])"/>
                                </td>
                                <td class="num">
                                    <span t-esc="'({:,.2f})'.format(abs(grand_total['allocated'])) if grand_total['allocated'] &lt; 0 else '{:,.2f}'.format(grand_total['allocated'])"/>
                                </td>
                                <td class="num">
                                    <span t-esc="'({:,.2f})'.format(abs(grand_total['balance'])) if grand_total['balance'] &lt; 0 else '{:,.2f}'.format(grand_total['balance'])"/>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                    </div>
                    </div>
                </div>
            </t>
        </t>
    </template>

</odoo>

<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_ft_financial_report_config_tree" model="ir.ui.view">
        <field name="name">ft.financial.report.config.tree</field>
        <field name="model">ft.financial.report.config</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"/>
                <field name="name"/>
                <field name="statement_type"/>
                <field name="company_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_ft_financial_report_config_form" model="ir.ui.view">
        <field name="name">ft.financial.report.config.form</field>
        <field name="model">ft.financial.report.config</field>
        <field name="arch" type="xml">
            <form string="Financial Report Configuration">
                <sheet>
                    <group col="4">
                        <field name="sequence"/>
                        <field name="name"/>
                        <field name="statement_type"/>
                        <field name="company_id"/>
                        <field name="active"/>
                    </group>
                    <field name="line_ids">
                        <list editable="bottom">
                            <field name="sequence"/>
                            <field name="code"/>
                            <field name="name"/>
                            <field name="parent_code"/>
                            <field name="level"/>
                            <field name="is_total"/>
                            <field name="sign"/>
                            <field name="account_ids" widget="many2many_tags"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ft_financial_report_config" model="ir.actions.act_window">
        <field name="name">Financial Report Configuration</field>
        <field name="res_model">ft.financial.report.config</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="action_ft_cash_flow_report_config" model="ir.actions.act_window">
        <field name="name">Cash Flow Report Configuration</field>
        <field name="res_model">ft.financial.report.config</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('statement_type', '=', 'cash_flow_custom')]</field>
        <field name="context">{'default_statement_type': 'cash_flow_custom'}</field>
    </record>

    <record id="view_ft_balance_sheet_wizard_form" model="ir.ui.view">
        <field name="name">ft.balance.sheet.wizard.form</field>
        <field name="model">ft.balance.sheet.wizard</field>
        <field name="arch" type="xml">
            <form string="Balance Sheet">
                <group col="4">
                    <field name="company_id"/>
                    <field name="currency_id"/>
                    <field name="date_to"/>
                    <field name="comparison_date_to"/>
                    <field name="target_move"/>
                    <field name="journal_ids" widget="many2many_tags"/>
                    <field name="analytic_account_ids" widget="many2many_tags"/>
                </group>
                <footer>
                    <button name="action_view" string="View" type="object" class="btn btn-secondary"/>
                    <button name="action_print" string="Print" type="object" class="oe_highlight"/>
                    <button name="check_report_xlsx" string="Download Excel" type="object" class="btn btn-secondary"/>
                    <button string="Cancel" special="cancel" class="btn btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_ft_balance_sheet_wizard" model="ir.actions.act_window">
        <field name="name">Balance Sheet</field>
        <field name="res_model">ft.balance.sheet.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_ft_balance_sheet_wizard_form"/>
        <field name="target">new</field>
    </record>

    <record id="view_ft_income_statement_wizard_form" model="ir.ui.view">
        <field name="name">ft.income.statement.wizard.form</field>
        <field name="model">ft.income.statement.wizard</field>
        <field name="arch" type="xml">
            <form string="Income Statement">
                <group col="4">
                    <field name="company_id"/>
                    <field name="currency_id"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                    <field name="comparison_date_from"/>
                    <field name="comparison_date_to"/>
                    <field name="target_move"/>
                    <field name="journal_ids" widget="many2many_tags"/>
                    <field name="analytic_account_ids" widget="many2many_tags"/>
                </group>
                <footer>
                    <button name="action_view" string="View" type="object" class="btn btn-secondary"/>
                    <button name="action_print" string="Print" type="object" class="oe_highlight"/>
                    <button name="check_report_xlsx" string="Download Excel" type="object" class="btn btn-secondary"/>
                    <button string="Cancel" special="cancel" class="btn btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_ft_income_statement_wizard" model="ir.actions.act_window">
        <field name="name">Income Statement</field>
        <field name="res_model">ft.income.statement.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_ft_income_statement_wizard_form"/>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_ft_financial_report_config"
              name="Financial Report Configuration"
              sequence="70"
              parent="account.menu_finance_reports"
              action="action_ft_financial_report_config"
              groups="account.group_account_manager"/>

    <menuitem id="menu_ft_cash_flow_report_config"
              name="Cash Flow Report Configuration"
              sequence="74"
              parent="account.menu_finance_reports"
              action="action_ft_cash_flow_report_config"
              groups="account.group_account_user,account.group_account_manager"/>

    <menuitem id="menu_ft_balance_sheet_report"
              name="Balance Sheet (Custom)"
              sequence="71"
              parent="account.menu_finance_reports"
              action="action_ft_balance_sheet_dynamic"
              groups="base_accounting_kit.group_account_chief,account.group_account_user"/>

    <menuitem id="menu_ft_income_statement_report"
              name="Income Statement (Custom)"
              sequence="72"
              parent="account.menu_finance_reports"
              action="action_ft_income_statement_dynamic"
              groups="base_accounting_kit.group_account_chief,account.group_account_user"/>

    <menuitem id="menu_ft_cash_flow_statement_report"
              name="Cash Flow Statement (Custom)"
              sequence="73"
              parent="account.menu_finance_reports"
              action="action_ft_custom_cash_flow_dynamic"
              groups="base_accounting_kit.group_account_chief,account.group_account_user"/>
</odoo>

<odoo>

    <record id="view_move_form_inherit_ft_rental_days" model="ir.ui.view">
        <field name="name">account.move.form.ft.rental.days</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header/field[@name='state']" position="after">
                <field name="approval_required" invisible="1"/>
                <field name="approval_stage"
                       widget="statusbar"
                       statusbar_visible="reviewer,confirmed"
                       invisible="not approval_required"/>
            </xpath>

            <xpath expr="//header" position="inside">
                <button name="action_set_reviewer"
                        string="Reviewer"
                        type="object"
                        class="btn btn-secondary"
                        groups="ft_backend.group_move_reviewer"
                        invisible="not approval_required or state != 'draft' or approval_stage == 'reviewer'"/>
                <button name="action_set_confirmed"
                        string="Confirmed"
                        type="object"
                        class="oe_highlight"
                        groups="ft_backend.group_move_confirmer"
                        invisible="not approval_required or state != 'draft' or approval_stage != 'reviewer'"/>
            </xpath>

            <xpath expr="//page[@id='invoice_tab']//field[@name='invoice_line_ids']/list/field[@name='quantity']" position="after">
                <field name="rental_days" string="Rental Days" optional="show"/>
            </xpath>
        </field>
    </record>

</odoo>

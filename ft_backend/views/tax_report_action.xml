<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="action_account_tax_report_new_wizard" model="ir.actions.act_window">
        <field name="name">Tax Report (New)</field>
        <field name="res_model">kit.account.tax.report</field>
        <field name="type">ir.actions.act_window</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="base_accounting_kit.accounting_tax_report_view"/>
        <field name="context">{'default_tax_scope': 'all', 'default_name': 'Tax Report (New)', 'use_new_tax_report': True}</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_tax_report_new"
              name="Tax Report (New)"
              sequence="11"
              action="action_account_tax_report_new_wizard"
              parent="base_accounting_kit.account_reports_audit"
              groups="base_accounting_kit.group_account_chief,account.group_account_user"/>

    <record id="base_accounting_kit.menu_sales_tax_report" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    <record id="base_accounting_kit.menu_purchase_tax_report" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

    <record id="menu_tax_report_new" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>

</odoo>

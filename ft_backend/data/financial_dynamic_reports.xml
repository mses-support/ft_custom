<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="ft_report_balance_sheet_dynamic" model="account.report">
            <field name="name">Balance Sheet (FT)</field>
            <field name="filter_date_range" eval="True"/>
            <field name="filter_period_comparison" eval="True"/>
            <field name="filter_journals" eval="True"/>
            <field name="filter_analytic" eval="True"/>
            <field name="filter_hierarchy">by_default</field>
            <field name="filter_show_draft" eval="True"/>
            <field name="default_opening_date_filter">today</field>
            <field name="column_ids">
                <record id="ft_report_balance_sheet_dynamic_col_balance" model="account.report.column">
                    <field name="name">Balance</field>
                    <field name="expression_label">balance</field>
                    <field name="figure_type">monetary</field>
                </record>
            </field>
            <field name="line_ids">
                <record id="ft_bs_assets" model="account.report.line">
                    <field name="name">ASSETS</field>
                    <field name="code">BS_ASSETS</field>
                    <field name="hierarchy_level">0</field>
                    <field name="foldable" eval="False"/>
                    <field name="expression_ids">
                        <record id="ft_bs_assets_expr" model="account.report.expression">
                            <field name="label">balance</field>
                            <field name="engine">aggregation</field>
                            <field name="formula">sum_children</field>
                        </record>
                    </field>
                    <field name="children_ids">
                        <record id="ft_bs_current_assets" model="account.report.line">
                            <field name="name">Current Assets</field>
                            <field name="code">BS_CURR_ASSETS</field>
                            <field name="hierarchy_level">1</field>
                            <field name="expression_ids">
                                <record id="ft_bs_current_assets_expr" model="account.report.expression">
                                    <field name="label">balance</field>
                                    <field name="engine">aggregation</field>
                                    <field name="formula">sum_children</field>
                                </record>
                            </field>
                            <field name="children_ids">
                                <record id="ft_bs_cash" model="account.report.line">
                                    <field name="name">Bank and Cash Accounts</field>
                                    <field name="code">BS_CASH</field>
                                    <field name="expression_ids">
                                        <record id="ft_bs_cash_expr" model="account.report.expression">
                                            <field name="label">balance</field>
                                            <field name="engine">domain</field>
                                            <field name="formula">[('account_id.account_type', '=', 'asset_cash')]</field>
                                            <field name="subformula">sum</field>
                                        </record>
                                    </field>
                                </record>
                                <record id="ft_bs_recv" model="account.report.line">
                                    <field name="name">Receivables</field>
                                    <field name="code">BS_RECV</field>
                                    <field name="expression_ids">
                                        <record id="ft_bs_recv_expr" model="account.report.expression">
                                            <field name="label">balance</field>
                                            <field name="engine">domain</field>
                                            <field name="formula">[('account_id.account_type', '=', 'asset_receivable')]</field>
                                            <field name="subformula">sum</field>
                                        </record>
                                    </field>
                                </record>
                                <record id="ft_bs_curr" model="account.report.line">
                                    <field name="name">Current Assets</field>
                                    <field name="code">BS_CURR</field>
                                    <field name="expression_ids">
                                        <record id="ft_bs_curr_expr" model="account.report.expression">
                                            <field name="label">balance</field>
                                            <field name="engine">domain</field>
                                            <field name="formula">[('account_id.account_type', '=', 'asset_current')]</field>
                                            <field name="subformula">sum</field>
                                        </record>
                                    </field>
                                </record>
                                <record id="ft_bs_prep" model="account.report.line">
                                    <field name="name">Prepayments</field>
                                    <field name="code">BS_PREP</field>
                                    <field name="expression_ids">
                                        <record id="ft_bs_prep_expr" model="account.report.expression">
                                            <field name="label">balance</field>
                                            <field name="engine">domain</field>
                                            <field name="formula">[('account_id.account_type', '=', 'asset_prepayments')]</field>
                                            <field name="subformula">sum</field>
                                        </record>
                                    </field>
                                </record>
                            </field>
                        </record>
                        <record id="ft_bs_noncurrent_assets" model="account.report.line">
                            <field name="name">Non-current Assets</field>
                            <field name="code">BS_NONCURR_ASSETS</field>
                            <field name="hierarchy_level">1</field>
                            <field name="expression_ids">
                                <record id="ft_bs_noncurrent_assets_expr" model="account.report.expression">
                                    <field name="label">balance</field>
                                    <field name="engine">aggregation</field>
                                    <field name="formula">sum_children</field>
                                </record>
                            </field>
                            <field name="children_ids">
                                <record id="ft_bs_fixed" model="account.report.line">
                                    <field name="name">Fixed Assets</field>
                                    <field name="code">BS_FIXED</field>
                                    <field name="expression_ids">
                                        <record id="ft_bs_fixed_expr" model="account.report.expression">
                                            <field name="label">balance</field>
                                            <field name="engine">domain</field>
                                            <field name="formula">[('account_id.account_type', '=', 'asset_fixed')]</field>
                                            <field name="subformula">sum</field>
                                        </record>
                                    </field>
                                </record>
                                <record id="ft_bs_noncurr" model="account.report.line">
                                    <field name="name">Other Non-current Assets</field>
                                    <field name="code">BS_NONCURR</field>
                                    <field name="expression_ids">
                                        <record id="ft_bs_noncurr_expr" model="account.report.expression">
                                            <field name="label">balance</field>
                                            <field name="engine">domain</field>
                                            <field name="formula">[('account_id.account_type', '=', 'asset_non_current')]</field>
                                            <field name="subformula">sum</field>
                                        </record>
                                    </field>
                                </record>
                            </field>
                        </record>
                    </field>
                </record>

                <record id="ft_bs_liab_eq" model="account.report.line">
                    <field name="name">LIABILITIES + EQUITY</field>
                    <field name="code">BS_LIAB_EQ</field>
                    <field name="hierarchy_level">0</field>
                    <field name="expression_ids">
                        <record id="ft_bs_liab_eq_expr" model="account.report.expression">
                            <field name="label">balance</field>
                            <field name="engine">aggregation</field>
                            <field name="formula">sum_children</field>
                        </record>
                    </field>
                    <field name="children_ids">
                        <record id="ft_bs_liabilities" model="account.report.line">
                            <field name="name">LIABILITIES</field>
                            <field name="code">BS_LIAB</field>
                            <field name="hierarchy_level">1</field>
                            <field name="expression_ids">
                                <record id="ft_bs_liabilities_expr" model="account.report.expression">
                                    <field name="label">balance</field>
                                    <field name="engine">aggregation</field>
                                    <field name="formula">sum_children</field>
                                </record>
                            </field>
                            <field name="children_ids">
                                <record id="ft_bs_curr_liab" model="account.report.line">
                                    <field name="name">Current Liabilities</field>
                                    <field name="code">BS_CURR_LIAB</field>
                                    <field name="expression_ids">
                                        <record id="ft_bs_curr_liab_expr" model="account.report.expression">
                                            <field name="label">balance</field>
                                            <field name="engine">domain</field>
                                            <field name="formula">[('account_id.account_type', '=', 'liability_current')]</field>
                                            <field name="subformula">-sum</field>
                                        </record>
                                    </field>
                                </record>
                                <record id="ft_bs_payable" model="account.report.line">
                                    <field name="name">Payables</field>
                                    <field name="code">BS_PAY</field>
                                    <field name="expression_ids">
                                        <record id="ft_bs_payable_expr" model="account.report.expression">
                                            <field name="label">balance</field>
                                            <field name="engine">domain</field>
                                            <field name="formula">[('account_id.account_type', '=', 'liability_payable')]</field>
                                            <field name="subformula">-sum</field>
                                        </record>
                                    </field>
                                </record>
                                <record id="ft_bs_noncurr_liab" model="account.report.line">
                                    <field name="name">Non-current Liabilities</field>
                                    <field name="code">BS_NONCURR_LIAB</field>
                                    <field name="expression_ids">
                                        <record id="ft_bs_noncurr_liab_expr" model="account.report.expression">
                                            <field name="label">balance</field>
                                            <field name="engine">domain</field>
                                            <field name="formula">[('account_id.account_type', '=', 'liability_non_current')]</field>
                                            <field name="subformula">-sum</field>
                                        </record>
                                    </field>
                                </record>
                            </field>
                        </record>
                        <record id="ft_bs_equity" model="account.report.line">
                            <field name="name">EQUITY</field>
                            <field name="code">BS_EQ</field>
                            <field name="hierarchy_level">1</field>
                            <field name="expression_ids">
                                <record id="ft_bs_equity_expr" model="account.report.expression">
                                    <field name="label">balance</field>
                                    <field name="engine">aggregation</field>
                                    <field name="formula">sum_children</field>
                                </record>
                            </field>
                            <field name="children_ids">
                                <record id="ft_bs_equity_main" model="account.report.line">
                                    <field name="name">Retained Earnings</field>
                                    <field name="code">BS_EQ_MAIN</field>
                                    <field name="expression_ids">
                                        <record id="ft_bs_equity_main_expr" model="account.report.expression">
                                            <field name="label">balance</field>
                                            <field name="engine">domain</field>
                                            <field name="formula">[('account_id.account_type', 'in', ('equity', 'equity_unaffected'))]</field>
                                            <field name="subformula">-sum</field>
                                        </record>
                                    </field>
                                </record>
                            </field>
                        </record>
                    </field>
                </record>
            </field>
        </record>

        <record id="ft_report_income_statement_dynamic" model="account.report">
            <field name="name">Income Statement (FT)</field>
            <field name="filter_date_range" eval="True"/>
            <field name="filter_period_comparison" eval="True"/>
            <field name="filter_journals" eval="True"/>
            <field name="filter_analytic" eval="True"/>
            <field name="filter_hierarchy">by_default</field>
            <field name="filter_show_draft" eval="True"/>
            <field name="default_opening_date_filter">this_year</field>
            <field name="column_ids">
                <record id="ft_report_income_statement_dynamic_col_balance" model="account.report.column">
                    <field name="name">Balance</field>
                    <field name="expression_label">balance</field>
                    <field name="figure_type">monetary</field>
                </record>
            </field>
            <field name="line_ids">
                <record id="ft_is_revenue" model="account.report.line">
                    <field name="name">Revenue</field>
                    <field name="code">IS_REV</field>
                    <field name="hierarchy_level">0</field>
                    <field name="expression_ids">
                        <record id="ft_is_revenue_expr" model="account.report.expression">
                            <field name="label">balance</field>
                            <field name="engine">domain</field>
                            <field name="formula">[('account_id.account_type', 'in', ('income', 'income_other'))]</field>
                            <field name="subformula">-sum</field>
                        </record>
                    </field>
                </record>
                <record id="ft_is_cost" model="account.report.line">
                    <field name="name">Cost of Sales</field>
                    <field name="code">IS_COST</field>
                    <field name="hierarchy_level">0</field>
                    <field name="expression_ids">
                        <record id="ft_is_cost_expr" model="account.report.expression">
                            <field name="label">balance</field>
                            <field name="engine">domain</field>
                            <field name="formula">[('account_id.account_type', '=', 'expense_direct_cost')]</field>
                            <field name="subformula">sum</field>
                        </record>
                    </field>
                </record>
                <record id="ft_is_gp" model="account.report.line">
                    <field name="name">Gross Profit (Loss)</field>
                    <field name="code">IS_GP</field>
                    <field name="hierarchy_level">0</field>
                    <field name="expression_ids">
                        <record id="ft_is_gp_expr" model="account.report.expression">
                            <field name="label">balance</field>
                            <field name="engine">aggregation</field>
                            <field name="formula">IS_REV.balance - IS_COST.balance</field>
                        </record>
                    </field>
                </record>
                <record id="ft_is_exp" model="account.report.line">
                    <field name="name">Expenses</field>
                    <field name="code">IS_EXP</field>
                    <field name="hierarchy_level">0</field>
                    <field name="expression_ids">
                        <record id="ft_is_exp_expr" model="account.report.expression">
                            <field name="label">balance</field>
                            <field name="engine">domain</field>
                            <field name="formula">[('account_id.account_type', 'in', ('expense', 'expense_depreciation'))]</field>
                            <field name="subformula">sum</field>
                        </record>
                    </field>
                </record>
                <record id="ft_is_op" model="account.report.line">
                    <field name="name">Operating Income (Loss)</field>
                    <field name="code">IS_OP</field>
                    <field name="hierarchy_level">0</field>
                    <field name="expression_ids">
                        <record id="ft_is_op_expr" model="account.report.expression">
                            <field name="label">balance</field>
                            <field name="engine">aggregation</field>
                            <field name="formula">IS_GP.balance - IS_EXP.balance</field>
                        </record>
                    </field>
                </record>
                <record id="ft_is_net" model="account.report.line">
                    <field name="name">Net Income (Loss)</field>
                    <field name="code">IS_NET</field>
                    <field name="hierarchy_level">0</field>
                    <field name="expression_ids">
                        <record id="ft_is_net_expr" model="account.report.expression">
                            <field name="label">balance</field>
                            <field name="engine">aggregation</field>
                            <field name="formula">IS_OP.balance</field>
                        </record>
                    </field>
                </record>
            </field>
        </record>

        <record id="action_ft_balance_sheet_dynamic" model="ir.actions.client">
            <field name="name">Balance Sheet</field>
            <field name="tag">ft_financial_report</field>
            <field name="context" eval="{'report_type': 'balance_sheet'}"/>
        </record>

        <record id="action_ft_income_statement_dynamic" model="ir.actions.client">
            <field name="name">Income Statement</field>
            <field name="tag">ft_financial_report</field>
            <field name="context" eval="{'report_type': 'income_statement'}"/>
        </record>

    </data>
</odoo>

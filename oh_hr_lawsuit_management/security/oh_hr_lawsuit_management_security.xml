<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data noupdate="1">
        <!-- Law suit module privilege -->
        <record id="res_groups_privilege_lawsuit" model="res.groups.privilege">
            <field name="name">Lawsuit</field>
            <field name="sequence">18</field>
            <field name="category_id" ref="base.module_category_human_resources"/>
        </record>
        <!-- Lawsuit officer group -->
        <record id="lawsuit_group_user" model="res.groups">
            <field name="name">Officer</field>
            <field name="privilege_id" ref="res_groups_privilege_lawsuit"/>
            <field name="implied_ids" eval="[(4, ref('hr.group_hr_user'))]"/>
        </record>
        <!-- Lawsuit manager group -->
        <record id="lawsuit_group_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="privilege_id" ref="res_groups_privilege_lawsuit"/>
            <field name="implied_ids" eval="[(4, ref('oh_hr_lawsuit_management.lawsuit_group_user'))]"/>
            <field name="user_ids"
                   eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>
        <!--Lawsuit manager rule-->
        <record id="lawsuit_comp_rule" model="ir.rule">
            <field name="name">Lawsuit multi-company</field>
            <field name="model_id" ref="model_hr_lawsuit"/>
            <field name="global" eval="True"/>
            <field name="domain_force">
                ['|',('company_id','=',False),('company_id','child_of',[user.company_id.id])]
            </field>
        </record>
    </data>
</odoo>

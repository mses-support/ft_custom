<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="account.action_analytic_reporting" model="ir.actions.act_window">
            <field name="name">Analytic Reporting</field>
            <field name="res_model">account.analytic.line</field>
            <field name="path">analytic-reporting</field>
            <field name="view_mode">graph,pivot</field>
            <field name="search_view_id" ref="account.view_account_analytic_line_filter_inherit_account"/>
            <field name="context">{
                'search_default_group_by_analytic_account': 1,
                'search_default_fiscal_date': 1,
                'group_by': ['date:month'],
            }</field>
            <field name="help">From this report, you can analyse analytic amounts with flexible groupings and measures, similar to the invoice analysis experience.</field>
        </record>

        <record id="account.menu_action_analytic_reporting" model="ir.ui.menu">
            <field name="name">Analytic Reporting</field>
        </record>
    </data>
</odoo>

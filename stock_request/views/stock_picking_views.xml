<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_picking_form" model="ir.ui.view">
        <field name="name">stock.picking.form</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form" />
        <field eval="12" name="priority" />
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button
                    type="object"
                    name="action_view_stock_request"
                    class="oe_stat_button"
                    icon="fa-chain"
                    invisible="stock_request_count == 0"
                >
                    <field
                        name="stock_request_count"
                        widget="statinfo"
                        string="Stock Requests"
                    />
                    <field name="stock_request_ids" invisible="1" />
                </button>
            </div>
            <xpath
                expr="//page[@name='operations']/field[@name='move_ids']/list/field[@name='product_id']"
                position="after"
            >
                <field name="cost" optional="show" />
                <field
                    name="analytic_account_id"
                    optional="show"
                    options="{'no_create': True}"
                />
            </xpath>
        </field>
    </record>
</odoo>
